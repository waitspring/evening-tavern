""""""""" 维护配置文件内的 SSL 配置项并重启服务单元
[root ~]# vim /etc/zookeeper/zoo.cfg
secureClientPort=2281

[root ~]# systemctl restart zookeeper.service
[root ~]# /usr/local/zookeeper/bin/zkCli.sh -server zookeeper-0.season.com:2181 ls -R /zookeeper
