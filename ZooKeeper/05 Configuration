""""""""" 维护实用工具内的 SSL 配置项
[root ~]# vim /usr/local/zookeeper/bin/zkServer.sh
export SERVER_JVMFLAGS="
-Dzookeeper.serverCnxnFactory=org.apache.zookeeper.server.NettyServerCnxnFactory
-Dzookeeper.ssl.keyStore.location=/etc/zookeeper/zookeeper.keystore.p12
-Dzookeeper.ssl.keyStore.type=PKCS12
-Dzookeeper.ssl.keyStore.password=season_4U
-Dzookeeper.ssl.trustStore.location=/etc/zookeeper/zookeeper.truststore.jks
-Dzookeeper.ssl.trustStore.type=JKS
-Dzookeeper.ssl.trustStore.password=season_4U"

[root ~]# sudo -u zookeeper cp /usr/local/zookeeper/bin/zkCli.sh /usr/local/zookeeper/bin/zkCli-ssl.sh
[root ~]# vim /usr/local/zookeeper/bin/zkCli-ssl.sh
export CLIENT_JVMFLAGS="
-Dzookeeper.clientCnxnSocket=org.apache.zookeeper.ClientCnxnSocketNetty
-Dzookeeper.client.secure=true
-Dzookeeper.ssl.keyStore.location=/etc/zookeeper/zookeeper.keystore.p12
-Dzookeeper.ssl.keyStore.type=PKCS12
-Dzookeeper.ssl.keyStore.password=season_4U
-Dzookeeper.ssl.trustStore.location=/etc/zookeeper/zookeeper.truststore.jks
-Dzookeeper.ssl.trustStore.type=JKS
-Dzookeeper.ssl.trustStore.password=season_4U"
