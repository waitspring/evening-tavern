ZooKeeper 软件的 SASL 配置
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ZooKeeper 软件的 SASL 配置需要使用如下要素:

    •  /etc/zookeeper/zoo.cfg                    维护主配置文件内 SASL 的参数配置项
    •  /etc/zookeeper/jaas-server.conf           ZooKeeper 服务端使用的 SASL 数据库文件, 登记用于安全认证的用户密码

    /etc/zookeeper/zoo.cfg
    -----------------------------------------------------------------
    # 服务端使用 SASLAuthenticationProvider 类对象验证用户身份, 0 值等于软件节点的 ID 编号
    authProvider.0=org.apache.zookeeper.server.auth.SASLAuthenticationProvider
    # 服务端开启 SASL 特性
    requireClientAuthScheme=sasl
    # 服务端在整个用户会话的生命周期内, 逐条命令验证用户身份
    sessionRequireClientSASLAuth=true

    /etc/zookeeper/jaas-server.conf
    -----------------------------------------------------------------
    Server {
        org.apache.zookeeper.server.auth.DigestLoginModule required
        user_kafka="kafka_4U";
    };

""""""""" 维护主配置文件内 SASL 的参数配置项
[root ~]# vim /etc/zookeeper/zoo.cfg
... ...
... ...
requireClientAuthScheme=sasl
authProvider.0=org.apache.zookeeper.server.auth.SASLAuthenticationProvider
sessionRequireClientSASLAuth=true
... ...
... ...
--------------------------------------------------------------------------------------------------------------------- ✻

""""""""" 维护服务端使用的 SASL 数据库文件
[root ~]# vim /etc/zookeeper/jaas-server.conf
Server {
    org.apache.zookeeper.server.auth.DigestLoginModule required
    user_kafka="kafka_4U";
};
--------------------------------------------------------------------------------------------------------------------- ✻



