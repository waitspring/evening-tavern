""""""""" 维护服务端使用的 SASL 数据库文件
[root ~]# vim /etc/zookeeper/jaas-server.conf
Server {
    org.apache.zookeeper.server.auth.DigestLoginModule required
    user_super="super_4U"
    user_admin="super_4U"
    user_kafka="kafka_4U";
};
--------------------------------------------------------------------------------------------------------------------- ✻

""""""""" 维护客户端使用的 SASL 数据库文件
[root ~]# vim /etc/zookeeper/jaas-super.conf
Client {
    org.apache.zookeeper.server.auth.DigestLoginModule required
    username="admin"
    password="super_4U";
};
--------------------------------------------------------------------------------------------------------------------- ✻

""""""""" 维护实用工具内的 SASL 配置项
[root ~]# vim /usr/local/zookeeper/bin/zkServer.sh (36)
