""""""""" 准备 Redis 软件的哨兵文件, 启动哨兵单元
[root ~]# sudo -u redis vim /etc/redis/conf.d/sentinel.conf
[root ~]# vim /usr/lib/systemd/system/redis-sentinel.service
[root ~]# systemctl daemon-reload
[root ~]# systemctl enable redis-sentinel.service
[root ~]# systemctl start redis-sentinel.service
