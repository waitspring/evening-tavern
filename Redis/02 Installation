""""""""" 演示启动调优的基本步骤
[root ~]# sed -i -r '/GRUB_CMDLINE_LINUX/s/(.+)="(.+)"/\1="\2 transparent_hugepage=never"/g' /etc/default/grub
[root ~]# grub2-mkconfig -o /boot/grub2/grub.cfg
[root ~]# reboot
