━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
/path/to/redis-cli [option...]
/path/to/redis-cli [option...] [command]
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
/path/to/redis-cli 命令是 Redis 软件的操作连接工具, 默认能够使用用户前台创建一个不断执行命令的 Redis 软件终端
/path/to/redis-cli 命令常用的可选选项有
::  -h HOSTNAME                    ( 127.0.0.1 ) 服务端的连接地址
::  -p PORT                             ( 6379 ) 服务端的连接端口
::  -n NUM                                 ( 0 ) 服务端的实例编号
::  -a PASSWORD                                  服务端的认证口令
::  -c                                           服务端为集群模式, 规避用户会话出现 -ASK -MOVED 请求异常
::            --tls                              要求工具创建 SSL 安全连接, 需要配合 --insecure/ --cacert 选项使用
::            --insecure                         要求工具不用 CA 文件校验服务端身份
::            --cacert=/PATH/TO/CA               要求工具使用 CA 文件校验服务端身份
::  -x                                           要求工具读取标准输入拼接为命令的一部分, 需要配合管道符号使用
::  -r NUM                                 ( 1 ) 服务端重复执行 NUM 次命令
::  -i NUM                                 ( 0 ) 服务端重复执行 NUM 次命令的同时, 设置轮询间隔为 NUM 秒钟
::            --slave                            要求工具模拟 Redis 从节点
::            --csv                              要求工具使用 CSV 表格的数据格式输出命令的执行结果
::            --rdb=/PATH/TO/FILE.RDB            要求工具复制 RDB 数据文件为 /PATH/TO/FILE.RDB 备份文件
::            --latency                          要求工具持续检测服务端的网络质量
::            --latency-history                  要求工具持续检测服务端的网络质量, 检测结果按照 15 秒钟分段计算
::            --latency-dist                     要求工具持续检测服务端的网络质量, 检测结果整理为数据图表
::            --stat                             要求工具持续呈报服务端的统计数据
::            --bigkeys                          要求工具统计键值对的数据元素情况, 呈报数据统计结果
::            --memkeys                          要求工具统计键值对的内存消耗情况, 呈报数据统计结果
::            --hotkeys                          要求工具统计键值对的读取访问情况, 呈报数据统计结果, 需要配合 LFU 算法使用
::            --no-raw                           要求工具展示二进制格式的原始数据

