━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Redis 软件使用 quicklist 数据结构缓存数组键值对, 数组键值对内部的每个字符串元素则各自使用 int embstr raw 编码格式

    + lpush                                                                                                rpush +
    ┌──────────────────┐          ┌──────────────────┐          ┌──────────────────┐          ┌──────────────────┐
    │ spring           │          │ summer           │          │ autumn           │          │ winter           │
    ├──────────────────┤ -------- ├──────────────────┤ -------- ├──────────────────┤ -------- ├──────────────────┤
    │ 0                │          │ 1                │          │ 2                │          │ 3                │
    └──────────────────┘          └──────────────────┘          └──────────────────┘          └──────────────────┘
    - lpop                                                                                                  rpop -

用户使用 redis-cli 命令能够使用用户前台创建一个不断执行命令的 Redis 软件终端, 其常用的数组命令有
::  rpush KEY ELEMENT ...                        在数组键值对右侧插入数量不定的字符串 ELEMENT ...
::  lpush KEY ELEMENT ...                        在数组键值对左侧插入数量不定的字符串 ELEMENT ...
::  linsert KEY { before | after } PIVOT ELEMENT 在数组键值对内部字符串等于 PIVOT 的元素前 (后) 位置插入字符串 ELEMENT
::  rpop KEY [NUM]                               在数组键值对右侧删除 1 个字符串元素 (使用可选参数 NUM 调整元素删除数量)
::  lpop KEY [NUM]                               在数组键值对左侧删除 1 个字符串元素 (使用可选参数 NUM 调整元素删除数量)
::  lrem KEY  NUM  PIVOT                         在数组键值对内部删除 NUM 个字符串值等于 PIVOT 的元素
::  ltrim KEY BEGIN END                          裁剪数组键值对, 保留 [BEGIN, END] 区间内的字符串元素, [0, -1] 为全部元素
::  lrange KEY BEGIN END                         查阅数组键值对, 回显 [BEGIN, END] 区间内的字符串元素, [0, -1] 为全部元素
::  lindex KEY IDX                               查阅数组键值对, 回显索引为 IDX 的字符串元素的值
::  lset KEY IDX VALUE                           更新数组键值对, 修改索引为 IDX 的字符串元素的值为 VALUE
::  llen KEY                                     统计数组键值对的宽度

    lrem KEY NUM PIVOT
    -----------------------------------------------------------------
    lrem 命令可用于在数组键值对内部删除 NUM 个字符串值等于 PIVOT 的元素, 其中:
        *  NUM = 0                               删除数组键值对内部全部字符串值等于 PIVOT 的元素
        *  NUM > 0                               从左向右正序删除数组键值对内部 NUM 个字符串值等于 PIVOT 的元素
        *  NUM < 0                               从右向左倒序删除数组键值对内部 NUM 个字符串值等于 PIVOT 的元素

""""""""" 演示数组命令的基本用法
[root ~]# redis-cli -h redis.season.com --tls --insecure
> rpush season spring summer autumn winter
> rpop season
"spring"
> lpop season
"autumn"
> linsert season before autumn equinox
> lrange season 0 -1
"summer"
"equinox"
"autumn"
