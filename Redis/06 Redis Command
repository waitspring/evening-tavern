━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
用户使用 redis-cli 命令能够使用用户前台创建一个不断执行命令的 Redis 软件终端, 其常用的终端命令有
::  help COMMAND                                 查阅 COMMAND 命令的帮助手册
::  ping                                         检查 Redis 软件服务的网络连接是否正常
::  shutdown                                     关闭 Redis 软件服务
::  select IDX                                   切换 Redis 软件当前实例为 IDX 编号的实例 (IDX 编号的默认取值范围为 0 ~ 15)
::  config set PARAM VALUE                       设置 Redis 软件 PARAM 配置项的值为 VALUE
::  config get PARAM                             查询 Redis 软件 PARAM 配置项的值
::  dbsize                                       统计 Redis 软件当前实例内键值对的数量
::  flushdb                                      擦除 Redis 软件当前实例的键值对
::  flushall                                     擦除 Redis 软件全部实例的键值对
::  bgsave                                       要求 Redis 软件触发 RDB 持久化存储工作流程
::  lastsave                                     查询 Redis 软件上次 RDB 持久化存储工作流程的触发时间点 (Unix 时间戳格式)
::  bgrewriteaof                                 要求 Redis 软件重写 AOF 数据文件
::  replicaof HOST PORT                          要求 Redis 软件当前实例成为 HOST:PORT 实例的从节点
::  replicaof no one                             要求 Redis 软件当前实例成为主节点

