""""""""" 维护认证表单并测试 SSL 连接
[root ~]# vim /etc/kafka/kafka-client-ssl.properties
security.protocol=SSL
ssl.keystore.location=/path/to/kafka.keystore.p12
ssl.keystore.password=season_4U
ssl.truststore.location=/path/to/kafka.truststore.jks
ssl.truststore.password=season_4U
[root ~]# bin/kafka-topics.sh --describe \
                              --bootstrap-server kafka-0.season.com:9092 \
                              --command-config /etc/kafka/kafka-client-ssl.properties
[root ~]# bin/kafka-console-consumer.sh --bootstrap-server kafka-0.season.com:9092 \
                                        --topic A \
                                        --group demo \
                                        --from-beginning \
                                        --property print.timestamp=true \
                                        --property print.key=true \
                                        --property print.headers=true \
                                        --consumer.config /etc/kafka/kafka-client-ssl.properties
