上游 ZooKeeper 软件使用 SSL 证书
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
上游 ZooKeeper 软件使用 SSL 证书, 要求下游 Kafka 软件服务注册时开启 SSL 特性

""""""""" 维护主配置文件内服务注册使用的 SSL 配置项
[root ~]# vim /etc/kafka/server.properties
... ...
... ...
zookeeper.connect=zookeeper-0.season.com:2281,zookeeper-1.season.com:2281,zookeeper-2.season.com:2281/kafka
zookeeper.ssl.client.enable=true
zookeeper.clientCnxnSocket=org.apache.zookeeper.ClientCnxnSocketNetty
... ...
... ...
[root ~]# systemctl restart kafka.service
